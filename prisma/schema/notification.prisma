model Notification {
     id        String           @id @default(uuid())
     userId    String           @map("user_id")
     user      User             @relation(fields: [userId], references: [id])
     title     String
     message   String
     type      NotificationType @default(SYSTEM)
     isRead    Boolean          @default(false)
     createdAt DateTime         @default(now())

     @@map("notifications")
}
