model MenuItem {
     id                   String   @id @default(uuid())
     name                 String
     slug                 String   @unique
     description          String
     price                Float
     discountPrice        Float?
     stock                Int      @default(0)
     images               String[] 
     ingredients          String?
     isVegetarian         Boolean  @default(false)
     spicyLevel           Int      @default(0) // 0-3 scale
     isActive             Boolean  @default(true)
     sku                  String?  @unique

     categoryId String
     category   Category @relation(fields: [categoryId], references: [id])

     chefId String
     chef   User   @relation("ChefMenuItems", fields: [chefId], references: [id])

     reviews           Review[]
     orderItems        OrderItem[]

     createdAt DateTime @default(now())
     updatedAt DateTime @updatedAt

     @@map("menu_items")
}
